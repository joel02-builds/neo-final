{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/*.py": { "runtime": "python3.9", "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/chat",      "destination": "/api/chat"      },
    { "source": "/api/uploads",   "destination": "/api/uploads"   },
    { "source": "/api/upload",    "destination": "/api/upload"    },
    { "source": "/api/save-file", "destination": "/api/save-file" },
    { "source": "/api/delete/:f", "destination": "/api/delete"    },
    { "source": "/(.*)",          "destination": "/index.html"    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
